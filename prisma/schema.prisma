model xase_storage_snapshots {
  id                 String       @id
  tenant_id          String
  dataset_id         String?
  lease_id           String?
  storage_bytes      BigInt       @default(0)
  storage_gb         Decimal      @default(0) @db.Decimal(15, 4)
  snapshot_type      String       @default("PERIODIC")
  snapshot_timestamp DateTime     @default(now()) @db.Timestamp(6)
  billing_period     String?
  hours_in_period    Decimal?     @default(1.0) @db.Decimal(10, 2)
  gb_hours           Decimal?     @default(dbgenerated("(storage_gb * hours_in_period)")) @db.Decimal(15, 4)
  metadata           Json?
  created_at         DateTime     @default(now()) @db.Timestamp(6)
  xase_datasets      Dataset?     @relation(fields: [dataset_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_storage_dataset")
  xase_access_leases AccessLease? @relation(fields: [lease_id], references: [id], onUpdate: NoAction, map: "fk_storage_lease")
  xase_tenants       Tenant       @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_storage_tenant")

  @@index([billing_period], map: "idx_storage_snapshots_billing_period")
  @@index([dataset_id], map: "idx_storage_snapshots_dataset")
  @@index([lease_id], map: "idx_storage_snapshots_lease")
  @@index([tenant_id], map: "idx_storage_snapshots_tenant")
  @@index([snapshot_timestamp], map: "idx_storage_snapshots_timestamp")
  @@index([snapshot_type], map: "idx_storage_snapshots_type")
}

model xase_subscriptions {
  id                     String          @id @db.VarChar(255)
  user_id                String          @db.VarChar(255)
  tenant_id              String?         @db.VarChar(255)
  stripe_subscription_id String          @unique @db.VarChar(255)
  stripe_customer_id     String          @db.VarChar(255)
  stripe_price_id        String          @db.VarChar(255)
  status                 String          @db.VarChar(50)
  plan_tier              String          @db.VarChar(50)
  current_period_start   DateTime        @db.Timestamp(6)
  current_period_end     DateTime        @db.Timestamp(6)
  cancel_at_period_end   Boolean?        @default(false)
  canceled_at            DateTime?       @db.Timestamp(6)
  created_at             DateTime?       @default(now()) @db.Timestamp(6)
  updated_at             DateTime?       @default(now()) @db.Timestamp(6)
  xase_invoices          xase_invoices[]
  users                  User            @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_subscription_user")

  @@index([status], map: "idx_subscriptions_status")
  @@index([stripe_customer_id], map: "idx_subscriptions_stripe_customer_id")
  @@index([tenant_id], map: "idx_subscriptions_tenant_id")
  @@index([user_id], map: "idx_subscriptions_user_id")
}

