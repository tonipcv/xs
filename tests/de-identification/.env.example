# XASE De-Identification Environment Configuration
# Copy this file to .env and configure for your environment

# ============================================================================
# Server Configuration
# ============================================================================
PORT=3000
NODE_ENV=production
LOG_LEVEL=info

# ============================================================================
# Processing Configuration
# ============================================================================
CONCURRENCY=8
BATCH_SIZE=100
TIMEOUT_SECONDS=30
MAX_FILE_SIZE_MB=50

# ============================================================================
# Quality Gates
# ============================================================================
MIN_REDACTION_RATE=95
MAX_VALIDATION_FAILURE_RATE=5
MIN_FILE_INTEGRITY_RATE=90

# ============================================================================
# Monitoring & Metrics
# ============================================================================
ENABLE_MONITORING=true
DASHBOARD_PORT=3000
METRICS_RETENTION_DAYS=30
PROMETHEUS_ENABLED=true

# ============================================================================
# Logging
# ============================================================================
LOG_DIR=/var/log/xase-deidentification
AUDIT_LOG_ENABLED=true
AUDIT_LOG_PATH=/var/log/xase-deidentification/audit.log

# ============================================================================
# Docker Services (Scenarios A-D)
# ============================================================================

# MinIO (S3-compatible storage)
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=hospital-data

# Orthanc (DICOMweb PACS)
ORTHANC_URL=http://localhost:8042
ORTHANC_USERNAME=orthanc
ORTHANC_PASSWORD=orthanc123
ORTHANC_AET=TESTPACS

# HAPI FHIR Server
HAPI_FHIR_URL=http://localhost:8080/fhir
HAPI_FHIR_VERSION=R4

# ============================================================================
# Webhook Configuration
# ============================================================================
WEBHOOK_ENABLED=false
WEBHOOK_URL=https://example.com/webhook
WEBHOOK_SECRET=change-me-in-production
WEBHOOK_RETRY_COUNT=3
WEBHOOK_TIMEOUT_MS=5000

# ============================================================================
# API Configuration
# ============================================================================
API_KEY=change-me-in-production
RATE_LIMIT_REQUESTS_PER_MINUTE=100
RATE_LIMIT_REQUESTS_PER_HOUR=1000
CORS_ENABLED=true
CORS_ORIGIN=*

# ============================================================================
# Security
# ============================================================================
ENABLE_HTTPS=false
SSL_CERT_PATH=/path/to/cert.pem
SSL_KEY_PATH=/path/to/key.pem
ENABLE_API_KEY_AUTH=false
ENABLE_JWT_AUTH=false
JWT_SECRET=change-me-in-production

# ============================================================================
# Data Paths
# ============================================================================
INPUT_DIR=/app/data/input
OUTPUT_DIR=/app/data/output
TEMP_DIR=/tmp/xase-deidentification
BACKUP_DIR=/app/data/backup

# ============================================================================
# Performance Tuning
# ============================================================================
NODE_OPTIONS=--max-old-space-size=2048
UV_THREADPOOL_SIZE=8
ENABLE_CLUSTERING=false
CLUSTER_WORKERS=4

# ============================================================================
# Feature Flags
# ============================================================================
ENABLE_DICOM=true
ENABLE_FHIR=true
ENABLE_TEXT=true
ENABLE_AUDIO=true
ENABLE_HL7=true
ENABLE_BATCH_PROCESSING=true
ENABLE_FILE_UPLOAD=true

# ============================================================================
# Advanced Options
# ============================================================================
DATE_SHIFT_DAYS_MIN=-182
DATE_SHIFT_DAYS_MAX=182
ENABLE_DATE_SHIFTING=true
ENABLE_UID_MAPPING=true
ENABLE_IDENTIFIER_HASHING=true
PRESERVE_MEDICAL_CONTENT=true

# ============================================================================
# Database (Optional - for audit logging)
# ============================================================================
DB_ENABLED=false
DB_HOST=localhost
DB_PORT=5432
DB_NAME=xase_deidentification
DB_USER=xase
DB_PASSWORD=change-me-in-production

# ============================================================================
# Redis (Optional - for caching)
# ============================================================================
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ============================================================================
# Email Notifications (Optional)
# ============================================================================
EMAIL_ENABLED=false
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=notifications@example.com
SMTP_PASSWORD=change-me-in-production
EMAIL_FROM=noreply@xase.ai
EMAIL_TO=ops@xase.ai

# ============================================================================
# Slack Notifications (Optional)
# ============================================================================
SLACK_ENABLED=false
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_CHANNEL=#deidentification-alerts

# ============================================================================
# Development/Testing
# ============================================================================
ENABLE_DEBUG_MODE=false
ENABLE_VERBOSE_LOGGING=false
SKIP_VALIDATION=false
GENERATE_TEST_DATA=false
