{
  "name": "@xase/de-identification-tests",
  "version": "2.1.0",
  "description": "Enterprise-grade de-identification system with binary DICOM support and real medical data validation",
  "scripts": {
    "test:dicom": "ts-node src/dicom-tests.ts",
    "test:dicom-binary": "ts-node src/dicom-binary-tests.ts",
    "test:dicom-image": "ts-node src/dicom-image-tests.ts",
    "test:fhir": "ts-node src/fhir-tests.ts",
    "test:text": "ts-node src/text-tests.ts",
    "test:audio": "ts-node src/audio-tests.ts",
    "test:hl7": "ts-node src/hl7-tests.ts",
    "test:all": "ts-node src/run-all-tests.ts",
    "test:integration": "ts-node src/full-integration-test.ts",
    "test:scenarios": "ts-node src/scenario-tests.ts",
    "test:edge-cases": "ts-node src/advanced-edge-cases.ts",
    "test:performance": "ts-node src/performance-benchmark.ts",
    "download:datasets": "ts-node src/download-datasets.ts",
    "download:dicom-real": "ts-node src/fetch-real-dicom.ts",
    "convert:dcm-to-json": "ts-node src/convert-dcm-to-json.ts",
    "generate:samples": "ts-node src/download-datasets.ts && ts-node src/download-clinical-texts.ts && ts-node src/generate-audio-samples.ts && ts-node src/generate-hl7-samples.ts",
    "validate:results": "ts-node src/validate-results.ts",
    "start:api": "ts-node src/api-server.ts",
    "build": "tsc",
    "dashboard": "ts-node src/monitoring-dashboard.ts",
    "quality-report": "ts-node src/quality-report-generator.ts",
    "batch": "ts-node src/batch-processor.ts",
    "docker:build": "./scripts/build-docker.sh",
    "test:complete": "./scripts/run-all-scenarios.sh",
    "test:real-dicom": "npm run download:dicom-real && npm run test:dicom-binary",
    "test:e2e": "ts-node src/end-to-end-test.ts",
    "test:full": "npm run test:real-dicom && npm run test:e2e && npm run quality-report"
  },
  "dependencies": {
    "axios": "^1.13.5",
    "compromise": "^14.10.0",
    "dicom-parser": "^1.8.21",
    "express": "^5.2.1",
    "fhir": "^4.11.1",
    "multer": "^2.0.2",
    "natural": "^6.10.0",
    "node-fetch": "^3.3.2",
    "sharp": "^0.33.0",
    "tar": "^6.2.0",
    "tesseract.js": "^5.0.0",
    "unzipper": "^0.10.14",
    "wav": "^1.0.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.10.0",
    "@types/unzipper": "^0.10.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
