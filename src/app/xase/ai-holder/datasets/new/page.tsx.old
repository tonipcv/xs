"use client"

import { useState, useEffect } from 'react'
import { AppLayout } from '@/components/AppSidebar'
import { Button } from '@/components/ui/button'
import { Input } from '@/components/ui/input'
import { Label } from '@/components/ui/label'
import { Textarea } from '@/components/ui/textarea'
import { Playfair_Display } from 'next/font/google'
import { useRouter } from 'next/navigation'
import { Cloud, Database, Check, Copy, ArrowLeft } from 'lucide-react'
import Link from 'next/link'

const heading = Playfair_Display({ subsets: ['latin'], weight: ['600', '700'] })

type IntegrationMode = 'aws-s3' | 'gcs' | 'azure-blob' | 'snowflake' | 'bigquery' | 'postgres' | null

const IAM_TEMPLATES = {
  'aws-s3': `{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:ListBucket"
      ],
      "Resource": [
        "arn:aws:s3:::YOUR_BUCKET_NAME",
        "arn:aws:s3:::YOUR_BUCKET_NAME/*"
      ],
      "Condition": {
        "StringEquals": {
          "aws:PrincipalOrgID": "xase-org-id"
        }
      }
    }
  ]
}`,
  'gcs': `{
  "bindings": [
    {
      "role": "roles/storage.objectViewer",
      "members": [
        "serviceAccount:xase-connector@xase-prod.iam.gserviceaccount.com"
      ],
      "condition": {
        "title": "Time-bound access",
        "expression": "request.time < timestamp('2024-12-31T23:59:59Z')"
      }
    }
  ]
}`,
  'azure-blob': `# Generate SAS token with read-only permissions
az storage container generate-sas \\
  --account-name YOUR_STORAGE_ACCOUNT \\
  --name YOUR_CONTAINER \\
  --permissions rl \\
  --expiry 2024-12-31T23:59:59Z \\
  --https-only`,
  'snowflake': `-- Create secure view for Xase
CREATE SECURE VIEW xase_voice_data AS
SELECT * FROM your_table
WHERE consent_status = 'VERIFIED';

-- Grant access to Xase role
GRANT SELECT ON VIEW xase_voice_data TO ROLE xase_connector;`,
  'bigquery': `-- Create authorized view
CREATE VIEW \`your-project.xase_dataset.voice_data\` AS
SELECT * FROM \`your-project.raw_dataset.voice_table\`
WHERE consent_status = 'VERIFIED';

-- Grant access to Xase service account
GRANT \`roles/bigquery.dataViewer\`
ON TABLE \`your-project.xase_dataset.voice_data\`
TO "serviceAccount:xase-connector@xase-prod.iam.gserviceaccount.com";`,
  'postgres': `-- Create read-only user for Xase
CREATE USER xase_connector WITH PASSWORD 'secure_password';
GRANT CONNECT ON DATABASE your_database TO xase_connector;
GRANT USAGE ON SCHEMA public TO xase_connector;
GRANT SELECT ON ALL TABLES IN SCHEMA public TO xase_connector;

-- Ensure read-only access
ALTER USER xase_connector SET default_transaction_read_only = on;`
}

export default function NewDatasetPage() {
  const router = useRouter()
  const [name, setName] = useState('')
  const [description, setDescription] = useState('')
  const [language, setLanguage] = useState('en-US')
  const [loading, setLoading] = useState(false)
  const [error, setError] = useState<string | null>(null)

  // No initialization needed - simple form


  const onSubmit = async (e: React.FormEvent) => {
    e.preventDefault()
    
    if (!name.trim()) {
      setError('Dataset name is required')
      return
    }
    
    setLoading(true)
    setError(null)
    
    try {
      const res = await fetch('/api/v1/datasets', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          name: name.trim(),
          description: description.trim() || undefined,
          language,
        }),
      })
      
      const data = await res.json()
      if (!res.ok) throw new Error(data.error || 'Failed to create dataset')
      
      const dsId = data?.datasetId || data?.dataset?.datasetId || data?.id || data?.dataset?.id
      if (dsId) {
        router.push(`/xase/voice/datasets/${dsId}`)
      } else {
        router.push('/xase/voice/datasets')
      }
    } catch (e: any) {
      setError(e.message || 'Error creating dataset')
    } finally {
      setLoading(false)
    }
  }

  const validateStorageFormat = (mode: IntegrationMode, value: string) => {
    if (!mode || !value) return false
    const v = value.trim()
    switch (mode) {
      case 'aws-s3':
        return /^s3:\/\/[a-z0-9.-]+\/[\S]*$/i.test(v)
      case 'gcs':
        return /^gs:\/\/[a-z0-9._-]+\/[\S]*$/i.test(v)
      case 'azure-blob':
        return /^https:\/\/[^\s]+\.blob\.core\.windows\.net\/[\S]+$/i.test(v)
      case 'snowflake':
        return /^(snowflake:\/\/|select\s+\*\s+from\s+)/i.test(v) || v.length > 0
      case 'bigquery':
        return /^(project\.|[a-z0-9-]+\.)?[a-z0-9_]+\.[a-z0-9_]+$/i.test(v) || /^bigquery:\/\//i.test(v)
      case 'postgres':
        return /^postgres(ql)?:\/\//i.test(v)
      default:
        return false
    }
  }

  const onTestConnection = async () => {
    setValidating(true)
    setValidationStatus('idle')
    try {
      const ok = validateStorageFormat(integrationMode, storageLocation)
      if (!ok) {
        setValidationStatus('failed')
        setError('Invalid storage location format for the selected integration mode')
        return
      }
      setValidationStatus('ok')
      setError(null)
    } finally {
      setValidating(false)
    }
  }

  function handleProviderClick(provider: 'AWS_S3' | 'GCS' | 'AZURE_BLOB' | 'BIGQUERY') {
    const actives = activeByProvider[provider] || []
    if (actives.length === 1) {
      const id = actives[0].id
      router.push(`/xase/voice/datasets/browse?integrationId=${id}`)
      return
    }
    router.push('/xase/data-holder/connectors')
  }

  // Show scanning state
  if (scanning) {
    return (
      <AppLayout>
        <div className="min-h-screen bg-gray-50 flex items-center justify-center">
          <div className="text-center">
            <div className="animate-spin h-16 w-16 border-4 border-blue-600 border-t-transparent rounded-full mx-auto mb-6" />
            <div className="text-xl font-semibold text-gray-900 mb-2">Scanning folder...</div>
            <div className="text-sm text-gray-600 max-w-md">
              Analyzing audio files in {storageLocation}
            </div>
          </div>
        </div>
      </AppLayout>
    )
  }

  return (
    <AppLayout>
      <div className="min-h-screen bg-gray-50">
        <div className="max-w-[1000px] mx-auto px-8 py-8 space-y-8">
          {/* Header */}
          <div className="space-y-2">
            <Link 
              href="/xase/voice/datasets"
              className="inline-flex items-center gap-2 text-sm text-gray-600 hover:text-gray-800 transition-colors"
            >
              <ArrowLeft className="w-4 h-4" />
              Back to Integrations
            </Link>
            <h1 className={`${heading.className} text-3xl font-semibold text-gray-900 tracking-tight`}>
              Connect Your Data
            </h1>
            <p className="text-sm text-gray-600">
              Choose your integration mode and configure access in 30–60 minutes
            </p>
          </div>

          {/* Step Indicator */}
          <div className="flex items-center gap-4">
            <div className={`flex items-center gap-2 ${step === 'mode' ? 'text-gray-900' : 'text-gray-400'}`}>
              <div className={`w-8 h-8 rounded-full flex items-center justify-center text-sm font-semibold ${step === 'mode' ? 'bg-gray-100' : 'bg-gray-50'}`}>
                1
              </div>
              <span className="text-sm">Integration Mode</span>
            </div>
            <div className="flex-1 h-px bg-gray-200" />
            <div className={`flex items-center gap-2 ${step === 'config' ? 'text-gray-900' : 'text-gray-400'}`}>
              <div className={`w-8 h-8 rounded-full flex items-center justify-center text-sm font-semibold ${step === 'config' ? 'bg-gray-100' : 'bg-gray-50'}`}>
                2
              </div>
              <span className="text-sm">Configuration</span>
            </div>
            <div className="flex-1 h-px bg-gray-200" />
            <div className={`flex items-center gap-2 ${step === 'review' ? 'text-gray-900' : 'text-gray-400'}`}>
              <div className={`w-8 h-8 rounded-full flex items-center justify-center text-sm font-semibold ${step === 'review' ? 'bg-gray-100' : 'bg-gray-50'}`}>
                3
              </div>
              <span className="text-sm">Review</span>
            </div>
          </div>

          {/* Step 1: Active Integrations + Provider Selection */}
          {step === 'mode' && (
            <div className="space-y-6">
              {activeIntegrations.length > 0 && (
                <div className="space-y-3">
                  <h2 className="text-xs font-medium text-gray-500 tracking-wide uppercase">Active integrations</h2>
                  <div className="space-y-2">
                    {activeIntegrations.map((intg) => (
                      <div key={intg.id} className="flex items-center justify-between p-3 border border-gray-200 rounded-lg bg-white">
                        <div className="min-w-0">
                          <div className="text-sm font-medium text-gray-900 truncate">{intg.name || intg.provider}</div>
                          <div className="text-[11px] text-gray-600">{intg.provider}</div>
                        </div>
                        <button
                          onClick={() => router.push(`/xase/voice/datasets/browse?integrationId=${intg.id}`)}
                          className="text-xs text-gray-700 hover:text-gray-900 underline"
                        >
                          Browse
                        </button>
                      </div>
                    ))}
                  </div>
                </div>
              )}

              <div>
                <h2 className={`${heading.className} text-xl font-semibold text-gray-900 mb-2`}>
                  Connect another source
                </h2>
                <p className="text-sm text-gray-600">
                  Select where your data currently lives. Xase will connect to it without moving or copying.
                </p>
              </div>

              <div className="grid gap-4 md:grid-cols-2">
                {/* Cloud Storage Options */}
                <button
                  onClick={() => handleProviderClick('AWS_S3')}
                  className="bg-white border border-gray-200 rounded-xl p-6 hover:bg-gray-50 transition-all text-left"
                >
                  <div className="flex items-start gap-4">
                    <div className="w-12 h-12 rounded-lg bg-gray-100 flex items-center justify-center flex-shrink-0">
                      <Cloud className="w-6 h-6 text-gray-700" />
                    </div>
                    <div className="flex-1">
                      <h3 className="text-base font-semibold text-gray-900 mb-1">AWS S3</h3>
                      <p className="text-xs text-gray-600 mb-2">Connect via IAM role with read-only access</p>
                      <span className="text-xs text-gray-500 font-mono">Recommended for most users</span>
                    </div>
                  </div>
                </button>

                <button
                  onClick={() => handleProviderClick('GCS')}
                  className="bg-white border border-gray-200 rounded-xl p-6 hover:bg-gray-50 transition-all text-left"
                >
                  <div className="flex items-start gap-4">
                    <div className="w-12 h-12 rounded-lg bg-gray-100 flex items-center justify-center flex-shrink-0">
                      <Cloud className="w-6 h-6 text-gray-700" />
                    </div>
                    <div className="flex-1">
                      <h3 className="text-base font-semibold text-gray-900 mb-1">Google Cloud Storage</h3>
                      <p className="text-xs text-gray-600 mb-2">Connect via service account</p>
                      <span className="text-xs text-gray-500 font-mono">Time-bound access</span>
                    </div>
                  </div>
                </button>

                <button
                  onClick={() => handleProviderClick('AZURE_BLOB')}
                  className="bg-white border border-gray-200 rounded-xl p-6 hover:bg-gray-50 transition-all text-left"
                >
                  <div className="flex items-start gap-4">
                    <div className="w-12 h-12 rounded-lg bg-gray-100 flex items-center justify-center flex-shrink-0">
                      <Cloud className="w-6 h-6 text-gray-700" />
                    </div>
                    <div className="flex-1">
                      <h3 className="text-base font-semibold text-gray-900 mb-1">Azure Blob Storage</h3>
                      <p className="text-xs text-gray-600 mb-2">Connect via SAS token</p>
                      <span className="text-xs text-gray-500 font-mono">Revocable access</span>
                    </div>
                  </div>
                </button>

                {/* Database Options */}
                <button
                  onClick={() => { setIntegrationMode('snowflake'); setStep('config'); }}
                  className="bg-white border border-gray-200 rounded-xl p-6 hover:bg-gray-50 transition-all text-left"
                >
                  <div className="flex items-start gap-4">
                      <div className="w-12 h-12 rounded-lg bg-gray-100 flex items-center justify-center flex-shrink-0">
                      <Database className="w-6 h-6 text-gray-700" />
                    </div>
                    <div className="flex-1">
                      <h3 className="text-base font-semibold text-gray-900 mb-1">Snowflake</h3>
                      <p className="text-xs text-gray-600 mb-2">Connect via secure view</p>
                      <span className="text-xs text-gray-500 font-mono">Query-proxy model</span>
                    </div>
                  </div>
                </button>

                <button
                  onClick={() => handleProviderClick('BIGQUERY')}
                  className="bg-white border border-gray-200 rounded-xl p-6 hover:bg-gray-50 transition-all text-left"
                >
                  <div className="flex items-start gap-4">
                    <div className="w-12 h-12 rounded-lg bg-gray-100 flex items-center justify-center flex-shrink-0">
                      <Database className="w-6 h-6 text-gray-700" />
                    </div>
                    <div className="flex-1">
                      <h3 className="text-base font-semibold text-gray-900 mb-1">BigQuery</h3>
                      <p className="text-xs text-gray-600 mb-2">Connect via authorized view</p>
                      <span className="text-xs text-gray-500 font-mono">Read-only access</span>
                    </div>
                  </div>
                </button>

                <button
                  onClick={() => { setIntegrationMode('postgres'); setStep('config'); }}
                  className="bg-white border border-gray-200 rounded-xl p-6 hover:bg-gray-50 transition-all text-left"
                >
                  <div className="flex items-start gap-4">
                    <div className="w-12 h-12 rounded-lg bg-gray-100 flex items-center justify-center flex-shrink-0">
                      <Database className="w-6 h-6 text-gray-700" />
                    </div>
                    <div className="flex-1">
                      <h3 className="text-base font-semibold text-gray-900 mb-1">Postgres</h3>
                      <p className="text-xs text-gray-600 mb-2">Connect via read replica</p>
                      <span className="text-xs text-gray-500 font-mono">On-prem or cloud</span>
                    </div>
                  </div>
                </button>
              </div>
            </div>
          )}

          {/* Step 2: Configuration */}
          {step === 'config' && integrationMode && (
            <div className="space-y-6">
              <div>
                <h2 className={`${heading.className} text-xl font-semibold text-gray-900 mb-2`}>
                  Configure Dataset
                </h2>
                <p className="text-sm text-gray-600">
                  Provide dataset details and storage location
                </p>
              </div>

              {/* Scan Results Summary */}
              {scanResults && (
                <div className="bg-blue-50 border border-blue-200 rounded-xl p-6 space-y-4">
                  <div className="flex items-center justify-between">
                    <h3 className="text-base font-semibold text-gray-900">Folder Summary</h3>
                    <Link
                      href={`/xase/voice/datasets/browse?integrationId=${integrationId}`}
                      className="text-sm text-blue-600 hover:text-blue-800 underline"
                    >
                      Change folder
                    </Link>
                  </div>
                  
                  <div className="grid grid-cols-3 gap-4">
                    <div className="bg-white rounded-lg p-4">
                      <div className="text-xs text-gray-600 mb-1">Audio Files</div>
                      <div className="text-2xl font-bold text-gray-900">{scanResults.numRecordings}</div>
                    </div>
                    <div className="bg-white rounded-lg p-4">
                      <div className="text-xs text-gray-600 mb-1">Total Duration</div>
                      <div className="text-2xl font-bold text-gray-900">
                        {scanResults.estimatedDurationHours.toFixed(1)}h
                      </div>
                    </div>
                    <div className="bg-white rounded-lg p-4">
                      <div className="text-xs text-gray-600 mb-1">Total Size</div>
                      <div className="text-2xl font-bold text-gray-900">
                        {(scanResults.totalSizeBytes / 1024 / 1024 / 1024).toFixed(2)} GB
                      </div>
                    </div>
                  </div>

                  <div className="pt-4 border-t border-blue-200">
                    <div className="text-xs text-gray-600 mb-2">Storage Location:</div>
                    <div className="font-mono text-sm bg-white p-3 rounded border border-blue-200 text-gray-900 break-all">
                      {storageLocation}
                    </div>
                  </div>

                  {scanResults.files && scanResults.files.length > 0 && (
                    <div>
                      <div className="text-xs text-gray-600 mb-2">File Preview (first 10):</div>
                      <div className="bg-white border border-blue-200 rounded-lg divide-y divide-gray-200 max-h-48 overflow-y-auto">
                        {scanResults.files.map((file: any, i: number) => (
                          <div key={i} className="p-2 text-xs">
                            <div className="font-mono text-gray-900">{file.name}</div>
                            <div className="text-gray-600">
                              {(file.size / 1024 / 1024).toFixed(2)} MB
                            </div>
                          </div>
                        ))}
                      </div>
                      {scanResults.numRecordings > 10 && (
                        <div className="text-xs text-gray-600 mt-2">
                          ...and {scanResults.numRecordings - 10} more files
                        </div>
                      )}
                    </div>
                  )}
                </div>
              )}

              {/* Selected Integration (if from browse flow) */}
              {integrationId && integrationName && !scanResults && (
                <div className="bg-blue-50 border border-blue-200 rounded-xl p-4">
                  <div className="flex items-center justify-between">
                    <div>
                      <div className="text-xs text-gray-600 mb-1">Using Integration:</div>
                      <div className="font-medium text-gray-900">{integrationName}</div>
                      <div className="text-xs text-gray-600 mt-0.5">{integrationProvider}</div>
                    </div>
                    <Link
                      href={`/xase/voice/datasets/browse?integrationId=${integrationId}`}
                      className="text-sm text-blue-600 hover:text-blue-800"
                    >
                      Change
                    </Link>
                  </div>
                </div>
              )}

              {/* IAM Template - only show if no integrationId (manual setup) */}
              {!integrationId && (
                <div className="bg-white border border-gray-200 rounded-xl p-6 space-y-4">
                  <div className="flex items-center justify-between">
                    <h3 className="text-sm font-semibold text-gray-900">Step 1: Grant Access</h3>
                    <Button
                      type="button"
                      size="sm"
                      variant="outline"
                      onClick={() => copyToClipboard(IAM_TEMPLATES[integrationMode])}
                      className="border-gray-300 text-gray-700 hover:bg-gray-50"
                    >
                      {copied ? <Check className="w-4 h-4" /> : <Copy className="w-4 h-4" />}
                      {copied ? 'Copied!' : 'Copy'}
                    </Button>
                  </div>
                  <p className="text-xs text-gray-600">
                    Apply this configuration to grant Xase read-only access to your data
                  </p>
                  <pre className="bg-gray-50 border border-gray-200 rounded-lg p-4 text-xs text-gray-700 font-mono overflow-x-auto">
                    {IAM_TEMPLATES[integrationMode]}
                  </pre>
                </div>
              )}

              {/* Dataset Details Form */}
              <form onSubmit={(e) => { e.preventDefault(); if (validationStatus === 'ok') setStep('review'); }} className="bg-white border border-gray-200 rounded-xl p-6 space-y-4">
                <h3 className="text-sm font-semibold text-gray-900">Step 2: Dataset Details</h3>
                
                <div>
                  <Label className="text-gray-700">Dataset Name</Label>
                  <Input 
                    value={name} 
                    onChange={(e)=>setName(e.target.value)} 
                    className="mt-1 bg-white border border-gray-300 text-gray-900 placeholder-gray-400" 
                    placeholder="e.g., Hospital Voice Recordings 2024" 
                    required 
                  />
                </div>

                <div>
                  <Label className="text-gray-700">Description</Label>
                  <Textarea 
                    value={description} 
                    onChange={(e)=>setDescription(e.target.value)} 
                    className="mt-1 bg-white border border-gray-300 text-gray-900 placeholder-gray-400 min-h-[80px]" 
                    placeholder="Describe the dataset, its purpose, and any relevant context"
                  />
                </div>

                <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                  <div>
                    <Label className="text-gray-700">Language</Label>
                    <Input 
                      value={language} 
                      onChange={(e)=>setLanguage(e.target.value)} 
                      className="mt-1 bg-white border border-gray-300 text-gray-900 placeholder-gray-400" 
                      placeholder="en, pt-BR, es" 
                      required 
                    />
                  </div>
                  <div>
                    <Label className="text-gray-700">Region</Label>
                    <Input 
                      value={region} 
                      onChange={(e)=>setRegion(e.target.value)} 
                      className="mt-1 bg-white border border-gray-300 text-gray-900 placeholder-gray-400" 
                      placeholder="us-east-1, eu-west-1" 
                    />
                  </div>
                </div>

                <div>
                  <Label className="text-gray-700">Storage Location</Label>
                  <Input 
                    value={storageLocation} 
                    onChange={(e)=>setStorageLocation(e.target.value)} 
                    className="mt-1 bg-white border border-gray-300 text-gray-900 placeholder-gray-400" 
                    placeholder={
                      integrationMode === 'aws-s3' ? 's3://your-bucket/voice-data/' :
                      integrationMode === 'gcs' ? 'gs://your-bucket/voice-data/' :
                      integrationMode === 'azure-blob' ? 'https://account.blob.core.windows.net/container' :
                      'Database connection string'
                    }
                    required 
                  />
                  <p className="text-xs text-gray-500 mt-1">
                    Your data stays here. Xase will only access it through governed policies.
                  </p>
                  <div className="flex items-center gap-2 mt-3">
                    <Button
                      type="button"
                      variant="outline"
                      className="border-gray-300 text-gray-700 hover:bg-gray-50"
                      onClick={onTestConnection}
                      disabled={validating}
                    >
                      {validating ? 'Testing…' : 'Test Connection'}
                    </Button>
                    {validationStatus === 'ok' && (
                      <span className="text-xs text-green-600">Connection looks good</span>
                    )}
                    {validationStatus === 'failed' && (
                      <span className="text-xs text-red-600">Validation failed</span>
                    )}
                  </div>
                </div>

                <div className="flex gap-2 pt-4">
                  <Button 
                    type="button" 
                    onClick={() => setStep('mode')}
                    variant="outline" 
                    className="border-gray-300 text-gray-700 hover:bg-gray-50"
                  >
                    Back
                  </Button>
                  <Button 
                    type="submit" 
                    className="bg-gray-900 hover:bg-gray-800 text-white"
                    disabled={validationStatus !== 'ok'}
                  >
                    Continue to Review
                  </Button>
                </div>
              </form>
            </div>
          )}

          {/* Step 3: Review & Submit */}
          {step === 'review' && (
            <div className="space-y-6">
              <div>
                <h2 className={`${heading.className} text-xl font-semibold text-gray-900 mb-2`}>
                  Review Integration
                </h2>
                <p className="text-sm text-gray-600">
                  Confirm your integration details before connecting
                </p>
              </div>

              <div className="bg-white border border-gray-200 rounded-xl p-6 space-y-4">
                <div className="grid gap-4 md:grid-cols-2">
                  <div>
                    <p className="text-xs text-gray-500 mb-1">Integration Mode</p>
                    <p className="text-sm text-gray-900 font-mono">{integrationMode?.toUpperCase()}</p>
                  </div>
                  <div>
                    <p className="text-xs text-gray-500 mb-1">Dataset Name</p>
                    <p className="text-sm text-gray-900">{name}</p>
                  </div>
                  <div>
                    <p className="text-xs text-gray-500 mb-1">Language</p>
                    <p className="text-sm text-gray-900 font-mono">{language}</p>
                  </div>
                  <div>
                    <p className="text-xs text-gray-500 mb-1">Region</p>
                    <p className="text-sm text-gray-900 font-mono">{region || 'Not specified'}</p>
                  </div>
                  <div className="md:col-span-2">
                    <p className="text-xs text-gray-500 mb-1">Storage Location</p>
                    <p className="text-sm text-gray-900 font-mono break-all">{storageLocation}</p>
                  </div>
                  {description && (
                    <div className="md:col-span-2">
                      <p className="text-xs text-gray-500 mb-1">Description</p>
                      <p className="text-sm text-gray-900">{description}</p>
                    </div>
                  )}
                </div>
              </div>

              {/* Security Confirmation */}
              <div className="bg-white border border-gray-200 rounded-xl p-6 space-y-3">
                <h3 className="text-sm font-semibold text-gray-900 flex items-center gap-2">
                  <Check className="w-4 h-4 text-gray-500" />
                  Security Confirmation
                </h3>
                <ul className="space-y-2 text-xs text-gray-600">
                  <li className="flex items-start gap-2">
                    <Check className="w-4 h-4 text-gray-500 flex-shrink-0 mt-0.5" />
                    <span>Your data will remain in your infrastructure</span>
                  </li>
                  <li className="flex items-start gap-2">
                    <Check className="w-4 h-4 text-gray-500 flex-shrink-0 mt-0.5" />
                    <span>Xase will only have read-only, time-bound access</span>
                  </li>
                  <li className="flex items-start gap-2">
                    <Check className="w-4 h-4 text-gray-500 flex-shrink-0 mt-0.5" />
                    <span>All access will be logged and auditable</span>
                  </li>
                  <li className="flex items-start gap-2">
                    <Check className="w-4 h-4 text-gray-500 flex-shrink-0 mt-0.5" />
                    <span>You can revoke access at any time</span>
                  </li>
                </ul>
              </div>

              {error && (
                <div className="bg-gray-50 border border-gray-200 rounded-xl p-4">
                  <p className="text-sm text-gray-700">{error}</p>
                </div>
              )}

              <div className="flex gap-2">
                <Button 
                  type="button" 
                  onClick={() => setStep('config')}
                  variant="outline" 
                  className="border-gray-300 text-gray-700 hover:bg-gray-50"
                >
                  Back
                </Button>
                <Button 
                  onClick={onSubmit}
                  disabled={loading}
                  className="bg-gray-900 text-white hover:bg-gray-800"
                >
                  {loading ? 'Connecting...' : 'Connect Dataset'}
                </Button>
              </div>
            </div>
          )}
        </div>
      </div>
    </AppLayout>
  )
}
