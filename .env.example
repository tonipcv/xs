# ============================================
# XASE SHEETS - Environment Variables Template
# ============================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git - it contains sensitive credentials

# ============================================
# NEXT.JS & AUTH
# ============================================
NODE_ENV=development
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-here-generate-with-openssl-rand-hex-32

# ============================================
# DATABASE
# ============================================
DATABASE_URL=postgres://user:password@host:port/database?sslmode=disable

# ============================================
# REDIS
# ============================================
REDIS_URL=redis://default:password@host:port
REDIS=redis://default:password@host:port

# ============================================
# EMAIL / SMTP
# ============================================
EMAIL_FROM_NAME=XASE
EMAIL_FROM_ADDRESS=noreply@example.com
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
ENABLE_EMAIL_OTP=false
DISABLE_EMAIL_OTP=true

# ============================================
# OAUTH PROVIDERS
# ============================================
# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# GCS OAuth
GCS_CLIENT_ID=your-gcs-client-id.apps.googleusercontent.com
GCS_CLIENT_SECRET=your-gcs-client-secret

# Azure AD OAuth (for NextAuth)
AZURE_AD_CLIENT_ID=your-azure-ad-client-id
AZURE_AD_CLIENT_SECRET=your-azure-ad-client-secret
AZURE_AD_TENANT_ID=your-azure-ad-tenant-id

# Azure OAuth (for storage/services)
AZURE_CLIENT_ID=your-azure-client-id
AZURE_CLIENT_SECRET=your-azure-client-secret
AZURE_TENANT_ID=your-azure-tenant-id

# AWS OAuth
AWS_OAUTH_CLIENT_ID=your-aws-oauth-client-id
AWS_OAUTH_CLIENT_SECRET=your-aws-oauth-client-secret

# ============================================
# STRIPE (BILLING)
# ============================================
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_INICIANTE_PRODUCT_ID=prod_your-iniciante-product-id
STRIPE_PRO_PRODUCT_ID=prod_your-pro-product-id

# ============================================
# AWS
# ============================================
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
KMS_KEY_ID=alias/your-kms-key-alias

# ============================================
# MINIO / S3
# ============================================
MINIO_SERVER_URL=https://minio.example.com
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=your-minio-password
BUCKET_NAME=xase
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true

# ============================================
# OPENAI
# ============================================
OPENAI_API_KEY=sk-proj-your-openai-api-key

# ============================================
# EVOLUTION API (WhatsApp)
# ============================================
EVOLUTION_API_URL=https://your-evolution-api.example.com
EVOLUTION_API_KEY=your-evolution-api-key

# ============================================
# XASE SPECIFIC
# ============================================
# Cron job secret for scheduled tasks
XASE_CRON_SECRET=your-cron-secret-generate-random

# KMS Configuration (mock or aws)
XASE_KMS_TYPE=mock

# Mock KMS Keys (for development only - generate with openssl)
XASE_MOCK_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----
your-private-key-here
-----END PRIVATE KEY-----"

XASE_MOCK_PUBLIC_KEY_PEM="-----BEGIN PUBLIC KEY-----
your-public-key-here
-----END PUBLIC KEY-----"

# Encryption key for sensitive data
ENCRYPTION_KEY=your-encryption-key-generate-random-32-chars

# External API key for integrations
EXTERNAL_API_KEY=your-external-api-key

# Dev admin token (development only)
DEV_ADMIN_TOKEN=dev-secret-token-change-in-production

# ============================================
# FEDERATED AGENT
# ============================================
FEDERATED_JWT_SECRET=your-federated-jwt-secret-generate-random
FEDERATED_AGENT_URL=http://localhost:8080
NEXTJS_URL=http://localhost:3000

# ============================================
# OPTIONAL / ADVANCED
# ============================================
# NGROK_URL=https://your-ngrok-url.ngrok-free.app
